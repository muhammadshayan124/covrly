# Copy to .env.local and fill in real values. Never commit .env.local (already gitignored).

# Required
AUTH_SECRET=                      # generate with: npx auth secret
DATABASE_URL=                     # Postgres connection string -- Vercel Postgres/Neon/Supabase all work

# Optional -- omit these and Covrly runs on MockProvider (simulated SMS, logged to the
# Message table and visible in the dashboard/staff portal). Set all three to send real
# texts via Twilio.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional -- omit these and the billing page shows a "not connected yet" state with an
# unlimited trial. Set all three to enable real Stripe Checkout upgrades.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Used to build absolute redirect URLs for Stripe Checkout.
NEXT_PUBLIC_APP_URL=http://localhost:3001
